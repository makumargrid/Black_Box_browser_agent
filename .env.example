# Service
BLACKBOX_HOST=0.0.0.0
BLACKBOX_PORT=8080
BLACKBOX_DB_PATH=blackbox_events.db
BLACKBOX_USE_PLAYWRIGHT=true
BLACKBOX_BROWSER_HEADLESS=false
BLACKBOX_STRICT_PLAYWRIGHT_RUNTIME=false

# Target + agent loop defaults (shared by live and demo)
BLACKBOX_TARGET_URL=http://localhost:3000
BLACKBOX_AGENT_MAX_STEPS=20
BLACKBOX_AGENT_STEP_DELAY_MS=1000

# Model selection
BLACKBOX_AGENT_MODEL=claude-sonnet-4-6
# BLACKBOX_AGENT_MODEL=claude-opus-4-7
# BLACKBOX_AGENT_MODEL=claude-haiku-4-5-20251001
BLACKBOX_GEMINI_MODEL=gemini-2.5-flash
# BLACKBOX_GEMINI_MODEL=gemini-3-pro-preview
# BLACKBOX_GEMINI_MODEL=gemini-2.5-pro
# BLACKBOX_GEMINI_MODEL=gemini-3-flash-preview
# BLACKBOX_GEMINI_MODEL=gemini-2.5-flash-lite
# NOTE: if one model is unavailable for your account/project, switch to another listed option.

# API keys (read from this .env file only)
ANTHROPIC_API_KEY=replace-me
GEMINI_API_KEY=replace-me
# GOOGLE_API_KEY=replace-me  # legacy alias for GEMINI_API_KEY
