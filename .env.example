# ============================================================
# Blackbox Agent — environment variable reference
# Copy to .env and fill in real values. Never commit real keys.
# ============================================================

# ── LLM API Keys (read from .env file only; terminal env is ignored) ────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ── Agent models ─────────────────────────────────────────────────────────────
BLACKBOX_AGENT_MODEL=claude-sonnet-4-6
BLACKBOX_GEMINI_MODEL=gemini-2.5-flash

# ── Service networking ────────────────────────────────────────────────────────
BLACKBOX_HOST=127.0.0.1
BLACKBOX_PORT=8080

# ── Browser / Playwright ─────────────────────────────────────────────────────
BLACKBOX_USE_PLAYWRIGHT=true
BLACKBOX_BROWSER_HEADLESS=false
BLACKBOX_STRICT_PLAYWRIGHT_RUNTIME=false

# ── Default target ────────────────────────────────────────────────────────────
BLACKBOX_TARGET_URL=http://127.0.0.1:3000/#/

# ── Agent step controls ───────────────────────────────────────────────────────
BLACKBOX_AGENT_MAX_STEPS=20
BLACKBOX_AGENT_STEP_DELAY_MS=1000

# ── HexStrike ToolChannel (Phase A only) ─────────────────────────────────────
# Set ENABLED=true only when running `docker compose --profile tools up`.
# When unreachable the system gracefully degrades to BIE-only mode.
BLACKBOX_HEXSTRIKE_ENABLED=false
BLACKBOX_HEXSTRIKE_URL=http://localhost:8888
BLACKBOX_HEXSTRIKE_TIMEOUT_S=300
# Hard cap for the tool-spend pool (separate from the engagement budget).
BLACKBOX_TOOL_BUDGET_HARD_CAP_USD=5.0

# ── Misc ─────────────────────────────────────────────────────────────────────
BLACKBOX_AUTO_OPEN_BROWSER=true
