flowchart LR
  %% ── Entry points ──────────────────────────────────────────────
  U[User / Teammate Agent] --> C[BlackboxClient or HTTP]
  U --> D[Demo CLI\ndemo_blackbox]
  U --> RA[run_agent.py\nbrowser-use path]

  %% ── Demo / API path ───────────────────────────────────────────
  D --> A[FastAPI App\nblackbox_service.api]
  C --> A
  A --> S[BlackboxService\norchestration core]

  %% ── Core service components ───────────────────────────────────
  S --> R[Browser Runtime\nPlaywrightRuntime or InMemoryRuntime]
  S --> FP[FailoverPlanner\nAnthropicPlanner → GeminiPlanner → RuleBasedPlanner]
  S --> E[SQLiteEventStore\nruns / events / tabs]
  S --> B[RunEventBus\nin-memory SSE stream]

  %% ── Planner internals ─────────────────────────────────────────
  FP --> AP[AnthropicPlanner\nClaude API primary]
  FP --> GP[GeminiPlanner\nGemini API fallback]
  FP --> RB[RuleBasedPlanner\nno API key fallback]

  %% ── Runtime outputs ───────────────────────────────────────────
  R --> T[Target Web App]
  R --> F[Artifacts Folder\nscreenshots]

  %% ── Dashboard / SSE ───────────────────────────────────────────
  B --> A
  A --> W[Dashboard UI\n/dashboard + SSE]
  E --> A

  %% ── Alternate agent path (browser-use) ────────────────────────
  RA --> BUA[browser_use_agent.py\nbrowser-use + LangChain]
  BUA --> DIS[display.py\nbrowser sidebar overlay\n+ Eruda DevTools]
  BUA --> T

  classDef core fill:#0f172a,stroke:#334155,color:#e2e8f0;
  classDef edge fill:#111827,stroke:#4b5563,color:#f3f4f6;
  classDef planner fill:#1e3a5f,stroke:#3b82f6,color:#bfdbfe;
  classDef agent fill:#1a2e1a,stroke:#4ade80,color:#bbf7d0;
  class S,A,R,FP,E,B core;
  class U,C,D,T,F,W,RA edge;
  class AP,GP,RB planner;
  class BUA,DIS agent;
